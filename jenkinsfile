pipeline {
  agent any

  environment {
    AWS_REGION = "ap-south-1"
    ACCOUNT_ID = "742710068961"
    ECR_REPO = "${ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com/my-app"
    CLUSTER_NAME = "three-tier-eks"
    GITHUB_TOKEN = credentials('github-token')
    KUBECONFIG = '/var/lib/jenkins/.kube/config'
  }

  stages {

   stage('Checkout') {
    steps {
        git(
            url: 'https://github.com/Ravichandu-git/End-to-End-project.git',
            branch: 'main',                // use your repo's default branch
            credentialsId: 'github-token'  // must match Jenkins credential ID
        )
    }
}

    stage('Build Docker Images') {
      steps {
        sh '''
        docker build -t frontend:${BUILD_NUMBER} ./frontend
        docker build -t backend:${BUILD_NUMBER} ./backend
        '''
      }
    }

    stage('Login to ECR') {
      steps {
        sh '''
        aws ecr get-login-password --region $AWS_REGION \
        | docker login --username AWS --password-stdin $ACCOUNT_ID.dkr.ecr.$AWS_REGION.amazonaws.com
        '''
      }
    }

    stage('Tag Images') {
    steps {
        sh '''
        docker tag frontend:${BUILD_NUMBER} $ECR_REPO:frontend-${BUILD_NUMBER}
        docker tag backend:${BUILD_NUMBER}  $ECR_REPO:backend-${BUILD_NUMBER}
        '''
    }
}

stage('Push to ECR') {
    steps {
        sh '''
        docker push $ECR_REPO:frontend-${BUILD_NUMBER}
        docker push $ECR_REPO:backend-${BUILD_NUMBER}
        '''
    }
}

    stage('Update kubeconfig') {
      steps {
        sh '''
        aws eks update-kubeconfig --region $AWS_REGION --name $CLUSTER_NAME
        '''
      }
   }
   
   stage('Check AWS Identity') {
  steps {
    sh '''
    aws sts get-caller-identity
    '''
  }
}

  stage('Deploy to Kubernetes') {
  steps {
    sh '''
    sed -i "s/REPLACE_TAG/${BUILD_NUMBER}/g" k8s/*.yaml

    kubectl apply -f k8s/namespace.yaml 

    kubectl apply -f k8s/backend.yaml
    kubectl apply -f k8s/backend-service.yaml
    kubectl apply -f k8s/frontend.yaml
    kubectl apply -f k8s/frontend-service.yaml
    '''
  }
}

  }
}
